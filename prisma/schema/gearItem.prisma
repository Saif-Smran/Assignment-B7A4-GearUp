model GearItem {
  id            String   @id @default(uuid())
  name          String
  description   String
  brand         String?
  pricePerDay   Decimal  @db.Decimal(10, 2)
  quantityTotal Int
  quantityAvail Int
  images        String[]
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  category      Category

  providerId String
  provider   User   @relation("ProviderGear", fields: [providerId], references: [id])

  rentalOrderItems RentalOrderItem[]
  reviews          Review[]

  @@index([category])
  @@index([providerId])
}
