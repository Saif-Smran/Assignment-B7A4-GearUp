model RentalOrderItem {
  id          String   @id @default(uuid())
  quantity    Int
  startDate   DateTime
  endDate     DateTime
  pricePerDay Decimal  @db.Decimal(10, 2)
  subtotal    Decimal  @db.Decimal(10, 2)

  rentalOrderId String
  rentalOrder   RentalOrder @relation(fields: [rentalOrderId], references: [id], onDelete: Cascade)
  gearItemId    String
  gearItem      GearItem    @relation(fields: [gearItemId], references: [id])
  // providerId    String
  // provider      GearItem    @relation("ProviderRentalOrderItems", fields: [providerId], references: [providerId])

  @@index([rentalOrderId])
  @@index([gearItemId])
  // @@index([providerId])
}